<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-android</TargetFramework>
    <OutputType>Exe</OutputType>
    <RootNamespace>PIDMobileSpeaker</RootNamespace>
    <UseMaui>true</UseMaui>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <ApplicationTitle>PID Mobile Speaker</ApplicationTitle>
    <ApplicationId>cz.pidmobilespeaker.app</ApplicationId>
    <ApplicationDisplayVersion>00.0001</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <SupportedOSPlatformVersion>23.0</SupportedOSPlatformVersion>
  </PropertyGroup>

  <ItemGroup>
    <MauiIcon Include="Resources\AppIcon\appicon.svg" ForegroundFile="Resources\AppIcon\appiconfg.svg" Color="#1A1A1A" />
    <MauiSplashScreen Include="Resources\Splash\splash.svg" Color="#1A1A1A" BaseSize="256,256" />
  </ItemGroup>

</Project>
